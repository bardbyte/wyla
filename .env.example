# Copy to .env and fill in. NEVER commit .env.

# SafeChain / CIBIS — get from CIBIS portal (ask team lead)
CIBIS_CONSUMER_INTEGRATION_ID=
CIBIS_CONSUMER_SECRET=

# Path to the SafeChain config.yml (model registry + IDaaS scopes)
CONFIG_PATH=./config/config.yml

# MDM API bearer token (if the MDM endpoint requires auth — confirm with data team)
MDM_BEARER_TOKEN=

# Optional: override GitHub host / token if cloning internal view repo requires it
# GIT_ASKPASS=
# GITHUB_TOKEN=
